{
  "manifest_version": 3,
  "name": "MoneyForward Toolpack",
  "description": "MoneyForward MEの家計簿ページで、AIを活用してサブスクリプション（固定費）候補を自動検出し、可視化・管理・見直しをサポートする拡張機能です。",
  "version": "0.1.12",
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "scripting",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://moneyforward.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "MoneyForward Toolpack",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": [
        "https://moneyforward.com/",
        "https://moneyforward.com/cf*",
        "https://moneyforward.com/accounts",
        "https://moneyforward.com/profile/rule",
        "https://moneyforward.com/spending_targets*",
        "https://moneyforward.com/bs*",
        "https://moneyforward.com/analysis/monthly_reports*"
      ],
      "js": ["src/content/index.js"],
      "css": ["src/content/style.css"],
      "run_at": "document_idle"
    }
  ]
}
